generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String           @id @default(cuid())
  clerkId              String           @unique
  email                String
  onboardingCompleted  Boolean          @default(false)
  onboardingStep       Int              @default(0)
  tier                 String           @default("free") // "free", "pro", "team"
  stripeCustomerId     String?          @unique
  licenceKey           String?          @unique
  subscriptionId       String?
  subscriptionEnd      DateTime?
  vaults               Vault[]
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  vaultSync            VaultSync?
  vaultMetadata        VaultMetadata?
  extensionTokens      ExtensionToken[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Vault {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?  @default("#22d68a")
  emoji       String?  @default("lock")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keys        Key[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Key {
  id             String   @id @default(cuid())
  service        String
  keyName        String
  encryptedValue String
  iv             String
  tag            String
  keyVersion     Int      @default(1)
  project        String?
  notes          String?
  vaultId        String
  vault          Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([vaultId, service, keyName])
  @@index([vaultId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  service   String?
  keyName   String?
  vaultName String?
  source    String   @default("dashboard") // "extension", "cli", "dashboard"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  hashedKey String    @unique
  prefix    String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([hashedKey])
}

model VaultSync {
  id             String   @id @default(cuid())
  userId         String   @unique
  encryptedVault String   @db.Text
  checksum       String
  version        Int      @default(1)
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VaultMetadata {
  id           String   @id @default(cuid())
  userId       String   @unique
  vaultCount   Int      @default(0)
  totalKeys    Int      @default(0)
  vaultsJson   String   @db.Text // JSON array of vault summaries
  servicesJson String   @db.Text // JSON array of service summaries
  lastModified DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExtensionToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
